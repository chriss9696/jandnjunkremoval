---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact J&N Junk Removal in Long Island, NY. Call (516) 672-5222 or schedule your pickup online. Fast response, free estimates.">

  <!-- PAGE HEADER -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="section-label">Get In Touch</p>
      <h1 class="section-title light">CONTACT US</h1>
      <p class="page-hero-sub">Ready to clear the clutter? Call, email, or fill out the form and we'll get back to you fast.</p>
    </div>
  </section>

  <!-- CONTACT STRIP -->
  <section class="contact-strip">
    <div class="container contact-strip-grid">
      <a href="tel:5166725222" class="contact-tile">
        <div class="contact-tile-icon">📞</div>
        <div>
          <div class="contact-tile-label">Call Us</div>
          <div class="contact-tile-value">(516) 672-5222</div>
        </div>
      </a>
      <a href="mailto:jnjunkremovalservices@gmail.com" class="contact-tile">
        <div class="contact-tile-icon">✉️</div>
        <div>
          <div class="contact-tile-label">Email Us</div>
          <div class="contact-tile-value">jnjunkremovalservices@gmail.com</div>
        </div>
      </a>
      <div class="contact-tile">
        <div class="contact-tile-icon">📍</div>
        <div>
          <div class="contact-tile-label">Service Area</div>
          <div class="contact-tile-value">Long Island, NY (516)</div>
        </div>
      </div>
      <div class="contact-tile">
        <div class="contact-tile-icon">⏰</div>
        <div>
          <div class="contact-tile-label">Hours</div>
          <div class="contact-tile-value">Mon–Sat: 7AM–7PM</div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTACT SECTION -->
  <section class="contact-main">
    <div class="container contact-grid">

      <!-- SCHEDULE FORM -->
      <div class="schedule-form" id="schedule">
        <p class="section-label">Book a Pickup</p>
        <h2 class="form-title">SCHEDULE YOUR<br />REMOVAL</h2>
        <div class="form-divider"></div>
        <p class="form-desc">Fill out the form below and we'll confirm your appointment within a few hours. Same-day service available — call <a href="tel:5166725222">(516) 672-5222</a> for fastest response.</p>

        <form class="booking-form" id="bookingForm" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="firstName">First Name *</label>
              <input type="text" id="firstName" name="firstName" required placeholder="John" />
            </div>
            <div class="form-group">
              <label for="lastName">Last Name *</label>
              <input type="text" id="lastName" name="lastName" required placeholder="Doe" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required placeholder="(516) 000-0000" />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" />
            </div>
          </div>

          <div class="form-group">
            <label for="address">Service Address *</label>
            <input type="text" id="address" name="address" required placeholder="123 Main St, Hempstead, NY 11550" />
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="service">Service Type *</label>
              <select id="service" name="service" required>
                <option value="">Select a service...</option>
                <option>Residential Junk Removal</option>
                <option>Commercial Cleanout</option>
                <option>Furniture & Appliance Removal</option>
                <option>Yard Waste Removal</option>
                <option>Construction Debris</option>
                <option>Estate Cleanout</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="date">Preferred Date *</label>
              <input type="date" id="date" name="date" required />
            </div>
          </div>

          <div class="form-group">
            <label for="timeSlot">Preferred Time</label>
            <select id="timeSlot" name="timeSlot">
              <option value="">Any time works</option>
              <option>Morning (7AM – 11AM)</option>
              <option>Midday (11AM – 2PM)</option>
              <option>Afternoon (2PM – 6PM)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Additional Details</label>
            <textarea id="message" name="message" rows="4" placeholder="Describe what needs to be removed, access details, apartment floor, etc."></textarea>
          </div>

          <button type="submit" class="btn btn-primary submit-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
            Request Pickup
          </button>

          <div class="form-note">
            🔒 Your info is never shared. We'll confirm by phone or email.
          </div>

          <div class="form-success" id="formSuccess">
            <div class="success-icon">✅</div>
            <h3>Request Sent!</h3>
            <p>We'll be in touch within a few hours to confirm your pickup. For faster service, call <a href="tel:5166725222">(516) 672-5222</a>.</p>
          </div>
        </form>
      </div>

      <!-- SIDEBAR INFO -->
      <div class="contact-sidebar">
        <!-- MAP -->
        <div class="map-section">
          <h3 class="sidebar-heading">OUR SERVICE AREA</h3>
          <div class="map-container" id="map">
            <!-- Embedded Google Map — Long Island, NY -->
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d193803.3194905997!2d-73.76836435!3d40.7282371!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c26eb8c15b6677%3A0x45a7c8bfb4fd7009!2sNassau%20County%2C%20NY!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="J&N Junk Removal Service Area – Long Island, NY"
            ></iframe>
          </div>
          <div class="service-areas">
            <h4>We Serve:</h4>
            <div class="areas-list">
              {['Valley Stream', 'Hempstead', 'Garden City', 'Freeport', 'Rockville Centre', 'Lynbrook', 'Baldwin', 'Merrick', 'Bellmore', 'Wantagh', 'Seaford', 'Massapequa', 'Long Beach', 'Oceanside', 'Elmont'].map(a => (
                <span class="area-tag">{a}</span>
              ))}
              <span class="area-tag more">+ More</span>
            </div>
          </div>
        </div>

        <!-- QUICK CONTACT -->
        <div class="quick-contact">
          <h3 class="sidebar-heading">CALL OR TEXT</h3>
          <a href="tel:5166725222" class="phone-big">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.12-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (516) 672-5222
          </a>
          <p class="quick-note">For same-day bookings, calling is fastest. We're available Mon–Sat, 7AM–7PM.</p>

          <div class="quick-divider"></div>

          <h3 class="sidebar-heading">EMAIL</h3>
          <a href="mailto:jnjunkremovalservices@gmail.com" class="email-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            jnjunkremovalservices@gmail.com
          </a>

          <div class="quick-divider"></div>

          <div class="trust-badges">
            <div class="trust-item">✅ Free Estimates</div>
            <div class="trust-item">✅ Same-Day Available</div>
            <div class="trust-item">✅ No Hidden Fees</div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Set min date to today
  const dateInput = document.getElementById('date') as HTMLInputElement;
  if (dateInput) {
    const today = new Date().toISOString().split('T')[0];
    dateInput.min = today;
  }

  // Form submission
  const form = document.getElementById('bookingForm') as HTMLFormElement;
  const successMsg = document.getElementById('formSuccess') as HTMLElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production: send to backend / EmailJS / Formspree / Netlify Forms
    // For now, show success message
    form.style.display = 'none';
    successMsg.style.display = 'block';

    // You can integrate with Formspree by adding action="https://formspree.io/f/YOUR_ID" to the form
    // and removing e.preventDefault()
  });
</script>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--black);
    padding: 80px 0 72px;
    position: relative;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 100% at 100% 50%, rgba(211,47,47,0.1) 0%, transparent 70%);
  }
  .page-hero-content { position: relative; z-index: 1; }
  .page-hero-sub { color: #888; font-size: 1rem; margin-top: 16px; max-width: 500px; }

  /* CONTACT STRIP */
  .contact-strip {
    background: var(--red);
    padding: 0;
  }

  .contact-strip-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .contact-tile {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 24px 20px;
    border-right: 1px solid rgba(255,255,255,0.2);
    color: var(--white);
    text-decoration: none;
    transition: background 0.2s;
    cursor: default;
  }

  a.contact-tile { cursor: pointer; }
  a.contact-tile:hover { background: rgba(0,0,0,0.15); }

  .contact-tile:last-child { border-right: none; }

  .contact-tile-icon { font-size: 1.6rem; flex-shrink: 0; }

  .contact-tile-label {
    font-family: var(--font-condensed);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.75;
    margin-bottom: 2px;
  }

  .contact-tile-value {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 1px;
  }

  /* MAIN CONTACT */
  .contact-main { padding: 80px 0; background: var(--gray-light); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: start;
  }

  /* FORM */
  .schedule-form {
    background: var(--white);
    padding: 48px 40px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.07);
  }

  .form-title {
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    letter-spacing: 1px;
    color: var(--black);
    margin-bottom: 16px;
  }

  .form-divider { width: 48px; height: 3px; background: var(--red); margin-bottom: 18px; }

  .form-desc { font-size: 0.95rem; color: var(--gray-text); line-height: 1.7; margin-bottom: 32px; }
  .form-desc a { color: var(--red); font-weight: 700; }

  .booking-form { display: flex; flex-direction: column; gap: 20px; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

  .form-group { display: flex; flex-direction: column; gap: 6px; }

  .form-group label {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--black);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px 16px;
    border: 2px solid var(--gray-mid);
    background: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--black);
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
    border-radius: 0;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--red);
  }

  .form-group textarea { resize: vertical; min-height: 100px; }

  .submit-btn { align-self: flex-start; padding: 16px 40px; font-size: 1rem; }

  .form-note {
    font-size: 0.8rem;
    color: var(--gray-text);
    margin-top: -8px;
  }

  .form-success {
    display: none;
    text-align: center;
    padding: 40px 20px;
  }

  .success-icon { font-size: 3rem; margin-bottom: 16px; }

  .form-success h3 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--black);
    margin-bottom: 12px;
  }

  .form-success p { color: var(--gray-text); line-height: 1.7; }
  .form-success a { color: var(--red); font-weight: 700; }

  /* SIDEBAR */
  .contact-sidebar { display: flex; flex-direction: column; gap: 24px; }

  .map-section, .quick-contact {
    background: var(--white);
    padding: 28px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }

  .sidebar-heading {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--red);
  }

  .map-container {
    margin-bottom: 20px;
    overflow: hidden;
  }

  .map-container iframe { display: block; }

  .service-areas h4 {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--gray-text);
    margin-bottom: 10px;
  }

  .areas-list { display: flex; flex-wrap: wrap; gap: 6px; }

  .area-tag {
    background: var(--gray-light);
    color: var(--black);
    font-size: 0.75rem;
    font-family: var(--font-condensed);
    font-weight: 600;
    padding: 4px 10px;
    letter-spacing: 0.5px;
  }

  .area-tag.more { background: var(--red); color: var(--white); }

  .phone-big {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--red);
    letter-spacing: 1px;
    margin-bottom: 10px;
    transition: color 0.2s;
  }
  .phone-big:hover { color: var(--red-dark); }

  .quick-note { font-size: 0.85rem; color: var(--gray-text); line-height: 1.6; }

  .quick-divider { width: 100%; height: 1px; background: var(--gray-mid); margin: 20px 0; }

  .email-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-condensed);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--black);
    word-break: break-all;
    transition: color 0.2s;
  }
  .email-link:hover { color: var(--red); }
  .email-link svg { flex-shrink: 0; color: var(--red); }

  .trust-badges { display: flex; flex-direction: column; gap: 8px; }

  .trust-item {
    font-family: var(--font-condensed);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
    color: var(--black);
  }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-strip-grid { grid-template-columns: 1fr 1fr; }
    .contact-tile { border-bottom: 1px solid rgba(255,255,255,0.2); }
    .contact-tile:nth-child(2), .contact-tile:nth-child(4) { border-right: none; }
    .schedule-form { padding: 32px 24px; }
  }

  @media (max-width: 600px) {
    .contact-strip-grid { grid-template-columns: 1fr; }
    .contact-tile { border-right: none; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
