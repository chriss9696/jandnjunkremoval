---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact J&N Junk Removal in Long Island, NY. Call (516) 981-3365 or schedule your pickup online. Fast response, free estimates.">

  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="section-label">Get In Touch</p>
      <h1 class="section-title light">CONTACT US</h1>
      <p class="page-hero-sub">Ready to clear the clutter? Call, email, or fill out the form and we'll get back to you fast.</p>
    </div>
  </section>

  <section class="contact-strip">
    <div class="container contact-strip-grid">
      <a href="tel:5169813365" class="contact-tile">
        <div class="contact-tile-icon">📞</div>
        <div><div class="contact-tile-label">Call Us</div><div class="contact-tile-value">(516) 981-3365</div></div>
      </a>
      <a href="mailto:jnjunkremovalservices@gmail.com" class="contact-tile">
        <div class="contact-tile-icon">✉️</div>
        <div><div class="contact-tile-label">Email Us</div><div class="contact-tile-value">jnjunkremovalservices@gmail.com</div></div>
      </a>
      <div class="contact-tile">
        <div class="contact-tile-icon">📍</div>
        <div><div class="contact-tile-label">Service Area</div><div class="contact-tile-value">Long Island, NY (516)</div></div>
      </div>
      <div class="contact-tile">
        <div class="contact-tile-icon">⏰</div>
        <div><div class="contact-tile-label">Hours</div><div class="contact-tile-value">Mon–Sat: 7AM–7PM</div></div>
      </div>
    </div>
  </section>

  <section class="contact-main">
    <div class="container contact-grid">

      <div class="schedule-form" id="schedule">
        <p class="section-label">Book a Pickup</p>
        <h2 class="form-title">SCHEDULE YOUR<br />REMOVAL</h2>
        <div class="form-divider"></div>
        <p class="form-desc">Fill out the form below and we'll confirm within a few hours. Same-day available — call <a href="tel:5169813365">(516) 981-3365</a> for fastest response.</p>

        <form id="bookingForm" novalidate>

          <div class="form-row">
            <div class="form-group">
              <label for="firstName">First Name *</label>
              <input type="text" id="firstName" name="firstName" required placeholder="John" />
            </div>
            <div class="form-group">
              <label for="lastName">Last Name *</label>
              <input type="text" id="lastName" name="lastName" required placeholder="Doe" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required placeholder="(516) 000-0000" />
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="you@example.com" />
            </div>
          </div>
          <div class="form-group">
            <label for="address">Service Address *</label>
            <input type="text" id="address" name="address" required placeholder="123 Main St, Hempstead, NY 11550" />
          </div>

          <div class="section-break"></div>

          <div class="sched-label">When works for you?</div>
          <p class="sched-sub">Optional — pick a date or choose next available and we'll reach out to confirm.</p>

          <div class="slot-options">
            <div class="slot-opt" id="opt-pick" onclick="setMode('pick')">
              <div class="slot-opt-icon">🗓️</div>
              <div>
                <div class="slot-opt-title">Pick a date</div>
                <div class="slot-opt-sub">Choose from calendar below</div>
              </div>
            </div>
            <div class="slot-opt" id="opt-asap" onclick="setMode('asap')">
              <div class="slot-opt-icon">⚡</div>
              <div>
                <div class="slot-opt-title">Next available</div>
                <div class="slot-opt-sub">We'll call to confirm your slot</div>
              </div>
            </div>
          </div>

          <div id="cal-wrap" class="cal-wrap hidden">
            <div class="cal-nav">
              <button type="button" class="cal-nav-btn" id="cal-prev">←</button>
              <span class="cal-month-label" id="cal-label">May 2026</span>
              <button type="button" class="cal-nav-btn" id="cal-next">→</button>
            </div>
            <div class="cal-days-hdr">
              <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
            </div>
            <div class="cal-grid" id="cal-grid"></div>
            <div class="time-slots hidden" id="time-slots">
              <div class="time-slots-label">Select a time window</div>
              <div class="time-grid">
                <button type="button" class="time-chip" data-time="morning">7AM – 11AM</button>
                <button type="button" class="time-chip" data-time="midday">11AM – 2PM</button>
                <button type="button" class="time-chip" data-time="afternoon">2PM – 6PM</button>
              </div>
            </div>
          </div>

          <div id="asap-box" class="asap-box hidden">
            <strong>Next available slot</strong> — we'll book you for our earliest opening (usually next business day at 8AM) and call to confirm the exact time within a few hours.
          </div>

          <div class="section-break"></div>

          <div class="consent-block">
            <label class="consent-label">
              <input type="checkbox" id="smsConsent" name="smsConsent" />
              <span class="consent-text">
                I agree to receive text messages from J&N Junk Removal at the number provided, including appointment reminders and service updates. Message &amp; data rates may apply. Message frequency varies.
              </span>
            </label>
            <div class="consent-note">
              Reply <strong>STOP</strong> at any time to unsubscribe from SMS messages. Reply <strong>HELP</strong> for help. Opting out will not affect your booking. See our <a href="/privacy">Privacy Policy</a>.
            </div>
          </div>

          <button type="submit" class="btn btn-primary submit-btn" id="submitBtn">
            🚛 Request Pickup
          </button>
          <div class="form-note">🔒 Your info is never shared. We'll confirm by phone or email within a few hours.</div>

        </form>

        <div class="form-success hidden" id="formSuccess">
          <div class="success-icon">✅</div>
          <h3>You're Booked!</h3>
          <p id="successMessage">We received your request and will confirm your pickup shortly.</p>
          <p>Questions? Call <a href="tel:5169813365">(516) 981-3365</a>.</p>
          <div id="calendarLink"></div>
        </div>

        <div class="form-error hidden" id="formError">
          <div class="error-icon">⚠️</div>
          <p>Something went wrong. Please call us at <a href="tel:5169813365">(516) 981-3365</a> or try again.</p>
          <button type="button" class="btn btn-primary" onclick="resetError()">Try Again</button>
        </div>
      </div>

      <div class="contact-sidebar">
        <div class="map-section">
          <h3 class="sidebar-heading">OUR SERVICE AREA</h3>
          <div class="map-container">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d193803.3194905997!2d-73.76836435!3d40.7282371!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c26eb8c15b6677%3A0x45a7c8bfb4fd7009!2sNassau%20County%2C%20NY!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus" width="100%" height="260" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="J&N Junk Removal Service Area – Long Island, NY"></iframe>
          </div>
          <div class="service-areas">
            <h4>We Serve:</h4>
            <div class="areas-list">
              {['Valley Stream','Hempstead','Garden City','Freeport','Rockville Centre','Lynbrook','Baldwin','Merrick','Bellmore','Wantagh','Seaford','Massapequa','Long Beach','Oceanside','Elmont'].map(a => (
                <span class="area-tag">{a}</span>
              ))}
              <span class="area-tag more">+ More</span>
            </div>
          </div>
        </div>
        <div class="quick-contact">
          <h3 class="sidebar-heading">CALL OR TEXT</h3>
          <a href="tel:5169813365" class="phone-big">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.12-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (516) 981-3365
          </a>
          <p class="quick-note">For same-day bookings, calling is fastest. Mon–Sat, 7AM–7PM.</p>
          <div class="quick-divider"></div>
          <h3 class="sidebar-heading">EMAIL</h3>
          <a href="mailto:jnjunkremovalservices@gmail.com" class="email-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            jnjunkremovalservices@gmail.com
          </a>
          <div class="quick-divider"></div>
          <div class="trust-badges">
            <div class="trust-item">✅ Free Estimates</div>
            <div class="trust-item">✅ Same-Day Available</div>
            <div class="trust-item">✅ No Hidden Fees</div>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  let bookingMode = '';
  let selectedDate = '';
  let selectedTime = '';
  let calYear = new Date().getFullYear();
  let calMonth = new Date().getMonth();

  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const TIME_LABELS: Record<string, string> = { morning: '7AM–11AM', midday: '11AM–2PM', afternoon: '2PM–6PM' };

  function setMode(mode: string) {
    bookingMode = mode;
    selectedDate = '';
    selectedTime = '';
    document.getElementById('opt-pick')!.classList.toggle('active', mode === 'pick');
    document.getElementById('opt-asap')!.classList.toggle('active', mode === 'asap');
    document.getElementById('cal-wrap')!.classList.toggle('hidden', mode !== 'pick');
    document.getElementById('asap-box')!.classList.toggle('hidden', mode !== 'asap');
    if (mode === 'pick') {
      renderCal();
      document.getElementById('time-slots')!.classList.add('hidden');
    }
  }

  function renderCal() {
    const grid = document.getElementById('cal-grid')!;
    document.getElementById('cal-label')!.textContent = `${MONTHS[calMonth]} ${calYear}`;
    const firstDay = new Date(calYear, calMonth, 1).getDay();
    const totalDays = new Date(calYear, calMonth + 1, 0).getDate();
    const today = new Date(); today.setHours(0,0,0,0);
    grid.innerHTML = '';
    for (let i = 0; i < firstDay; i++) {
      const el = document.createElement('div');
      el.className = 'cal-day empty';
      grid.appendChild(el);
    }
    for (let d = 1; d <= totalDays; d++) {
      const dt = new Date(calYear, calMonth, d);
      const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const el = document.createElement('div');
      const isPast = dt < today;
      const isSun  = dt.getDay() === 0;
      const isToday = dt.getTime() === today.getTime();
      el.className = 'cal-day' + (isPast || isSun ? ' disabled' : '') + (isToday ? ' today' : '') + (selectedDate === dateStr ? ' selected' : '');
      el.textContent = String(d);
      if (!isPast && !isSun) {
        el.addEventListener('click', () => selectDate(dateStr, el));
      }
      grid.appendChild(el);
    }
  }

  function selectDate(dateStr: string, el: HTMLElement) {
    selectedDate = dateStr;
    selectedTime = '';
    document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
    el.classList.add('selected');
    document.querySelectorAll('.time-chip').forEach(c => c.classList.remove('active'));
    document.getElementById('time-slots')!.classList.remove('hidden');
  }

  document.getElementById('cal-prev')!.addEventListener('click', () => {
    calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; } renderCal();
  });
  document.getElementById('cal-next')!.addEventListener('click', () => {
    calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; } renderCal();
  });

  document.querySelectorAll('.time-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      selectedTime = (chip as HTMLElement).dataset.time || '';
      document.querySelectorAll('.time-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });

  document.getElementById('bookingForm')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const payload = {
      first_name:     (document.getElementById('firstName') as HTMLInputElement).value.trim(),
      last_name:      (document.getElementById('lastName') as HTMLInputElement).value.trim(),
      phone:          (document.getElementById('phone') as HTMLInputElement).value.trim(),
      email:          (document.getElementById('email') as HTMLInputElement).value.trim(),
      address:        (document.getElementById('address') as HTMLInputElement).value.trim(),
      mode:           bookingMode || 'asap',
      preferred_date: selectedDate,
      preferred_time: selectedTime,
      sms_consent:    (document.getElementById('smsConsent') as HTMLInputElement).checked,
      source:         'website_contact_form',
    };

    if (!payload.first_name || !payload.last_name || !payload.phone || !payload.email || !payload.address) {
      btn.disabled = false;
      btn.textContent = '🚛 Request Pickup';
      return;
    }

    try {
      const res = await fetch('https://matrixautomate.org/api/jnjunk/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        const result = await res.json();
        document.getElementById('bookingForm')!.classList.add('hidden');
        document.getElementById('formSuccess')!.classList.remove('hidden');

        const isAsap = payload.mode === 'asap' || !selectedDate;
        document.getElementById('successMessage')!.textContent = isAsap
          ? "You've been booked for our next available slot. We'll call shortly to confirm your exact pickup time."
          : `Your appointment for ${MONTHS[parseInt(selectedDate.split('-')[1])-1]} ${parseInt(selectedDate.split('-')[2])}, ${selectedDate.split('-')[0]} (${TIME_LABELS[selectedTime] || ''}) has been confirmed.`;

        if (result.calendar_link) {
          document.getElementById('calendarLink')!.innerHTML =
            `<a href="${result.calendar_link}" target="_blank" class="cal-add-link">📅 Add to Google Calendar</a>`;
        }
      } else {
        showError();
      }
    } catch { showError(); }
  });

  function showError() {
    document.getElementById('bookingForm')!.classList.add('hidden');
    document.getElementById('formError')!.classList.remove('hidden');
  }

  function resetError() {
    document.getElementById('bookingForm')!.classList.remove('hidden');
    document.getElementById('formError')!.classList.add('hidden');
    const btn = document.getElementById('submitBtn') as HTMLButtonElement;
    btn.disabled = false;
    btn.textContent = '🚛 Request Pickup';
  }

  (window as any).setMode = setMode;
  (window as any).resetError = resetError;
</script>

<style>
  .page-hero { background: var(--black); padding: 80px 0 72px; position: relative; overflow: hidden; }
  .page-hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 100% at 100% 50%, rgba(211,47,47,0.1) 0%, transparent 70%); }
  .page-hero-content { position: relative; z-index: 1; }
  .page-hero-sub { color: #888; font-size: 1rem; margin-top: 16px; max-width: 500px; }

  .contact-strip { background: var(--red); padding: 0; }
  .contact-strip-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .contact-tile { display: flex; align-items: center; gap: 14px; padding: 24px 20px; border-right: 1px solid rgba(255,255,255,0.2); color: var(--white); text-decoration: none; transition: background 0.2s; cursor: default; }
  a.contact-tile { cursor: pointer; }
  a.contact-tile:hover { background: rgba(0,0,0,0.15); }
  .contact-tile:last-child { border-right: none; }
  .contact-tile-icon { font-size: 1.6rem; flex-shrink: 0; }
  .contact-tile-label { font-family: var(--font-condensed); font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; opacity: 0.75; margin-bottom: 2px; }
  .contact-tile-value { font-family: var(--font-condensed); font-weight: 700; font-size: 0.95rem; letter-spacing: 1px; }

  .contact-main { padding: 80px 0; background: var(--gray-light); }
  .contact-grid { display: grid; grid-template-columns: 1fr 360px; gap: 48px; align-items: start; }

  .schedule-form { background: var(--white); padding: 48px 40px; box-shadow: 0 4px 30px rgba(0,0,0,0.07); }
  .form-title { font-family: var(--font-display); font-size: 2.4rem; line-height: 1; letter-spacing: 1px; color: var(--black); margin-bottom: 16px; }
  .form-divider { width: 48px; height: 3px; background: var(--red); margin-bottom: 18px; }
  .form-desc { font-size: 0.95rem; color: var(--gray-text); line-height: 1.7; margin-bottom: 28px; }
  .form-desc a { color: var(--red); font-weight: 700; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
  .form-group label { font-family: var(--font-condensed); font-weight: 700; font-size: 0.85rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--black); }
  .form-group input { padding: 12px 16px; border: 2px solid var(--gray-mid); background: var(--white); font-family: var(--font-body); font-size: 0.95rem; color: var(--black); outline: none; transition: border-color 0.2s; border-radius: 0; }
  .form-group input:focus { border-color: var(--red); }

  .section-break { border: none; border-top: 1px solid var(--gray-mid); margin: 24px 0; }

  .sched-label { font-family: var(--font-condensed); font-weight: 700; font-size: 0.9rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--black); margin-bottom: 6px; }
  .sched-sub { font-size: 0.9rem; color: var(--gray-text); line-height: 1.6; margin-bottom: 16px; }

  .slot-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
  .slot-opt { border: 2px solid var(--gray-mid); padding: 14px 12px; cursor: pointer; transition: all 0.15s; display: flex; align-items: flex-start; gap: 10px; }
  .slot-opt:hover { border-color: var(--red); }
  .slot-opt.active { border-color: var(--red); background: rgba(226,75,74,0.04); }
  .slot-opt-icon { font-size: 1.4rem; flex-shrink: 0; }
  .slot-opt-title { font-family: var(--font-condensed); font-weight: 700; font-size: 0.9rem; color: var(--black); margin-bottom: 2px; }
  .slot-opt-sub { font-size: 0.75rem; color: var(--gray-text); }

  .cal-wrap { border: 1px solid var(--gray-mid); padding: 16px; background: #fafafa; margin-bottom: 16px; }
  .cal-wrap.hidden { display: none; }
  .cal-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .cal-nav-btn { background: none; border: 1px solid var(--gray-mid); padding: 4px 12px; cursor: pointer; font-size: 14px; color: var(--gray-text); font-family: var(--font-body); transition: all 0.15s; }
  .cal-nav-btn:hover { border-color: var(--red); color: var(--red); }
  .cal-month-label { font-family: var(--font-condensed); font-size: 0.9rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--black); }
  .cal-days-hdr { display: grid; grid-template-columns: repeat(7,1fr); gap: 2px; margin-bottom: 4px; }
  .cal-days-hdr span { font-family: var(--font-condensed); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--gray-text); text-align: center; padding: 4px 0; letter-spacing: 0.5px; }
  :global(.cal-grid) { display: grid; grid-template-columns: repeat(7,1fr); gap: 2px; }
  :global(.cal-day) { font-family: var(--font-condensed); font-size: 0.85rem; text-align: center; padding: 8px 4px; cursor: pointer; color: var(--black); transition: all 0.1s; border: 1px solid transparent; }
  :global(.cal-day.empty) { visibility: hidden; }
  :global(.cal-day:hover:not(.disabled):not(.empty)) { background: rgba(226,75,74,0.08); border-color: var(--red); color: var(--red); }
  :global(.cal-day.disabled) { color: var(--gray-mid); cursor: not-allowed; }
  :global(.cal-day.today) { font-weight: 700; color: var(--red); }
  :global(.cal-day.selected) { background: var(--red); color: var(--white); border-color: var(--red); }

  .time-slots { margin-top: 14px; }
  .time-slots.hidden { display: none; }
  .time-slots-label { font-family: var(--font-condensed); font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; color: var(--black); margin-bottom: 8px; }
  .time-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
  .time-chip { border: 1px solid var(--gray-mid); background: var(--white); padding: 9px 6px; font-family: var(--font-condensed); font-size: 0.8rem; font-weight: 600; color: var(--gray-text); cursor: pointer; transition: all 0.1s; letter-spacing: 0.3px; }
  .time-chip:hover { border-color: var(--red); color: var(--red); }
  .time-chip.active { background: var(--red); color: var(--white); border-color: var(--red); }

  .asap-box { background: #FFF8F0; border: 1px solid #FAC775; padding: 14px 16px; font-size: 0.88rem; color: #633806; line-height: 1.6; margin-bottom: 16px; }
  .asap-box.hidden { display: none; }
  .asap-box strong { color: #A32D2D; }

  .consent-block { background: var(--gray-light); padding: 16px; margin-bottom: 8px; }
  .consent-label { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; }
  .consent-label input[type="checkbox"] { margin-top: 2px; flex-shrink: 0; width: 16px; height: 16px; accent-color: var(--red); cursor: pointer; }
  .consent-text { font-size: 0.82rem; color: var(--gray-text); line-height: 1.6; }
  .consent-note { font-size: 0.78rem; color: var(--gray-text); line-height: 1.5; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--gray-mid); }
  .consent-note a { color: var(--red); }
  .consent-note strong { color: var(--black); }

  .submit-btn { width: 100%; padding: 16px 24px; font-size: 1rem; margin-top: 16px; display: flex; align-items: center; justify-content: center; gap: 8px; }
  .form-note { font-size: 0.78rem; color: var(--gray-text); text-align: center; margin-top: 10px; }

  .form-success, .form-error { text-align: center; padding: 40px 20px; }
  .form-success.hidden, .form-error.hidden { display: none; }
