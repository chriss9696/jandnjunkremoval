---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    img: '/images/residential-service.jpg',
    title: 'Residential Junk Removal',
    desc: 'Your home deserves to breathe. We haul away clutter, unwanted furniture, old electronics, and anything else taking up space — fast and affordable.',
    items: ['Old furniture & mattresses', 'Appliances & electronics', 'Garage & basement cleanouts', 'Attic clearing', 'General household junk'],
  },
  {
    img: '/images/commercial-service.jpg',
    title: 'Commercial Cleanouts',
    desc: 'Minimize downtime. We work around your schedule to clear out offices, retail spaces, and warehouses efficiently.',
    items: ['Office furniture & equipment', 'Retail fixture removal', 'Warehouse cleanouts', 'Storage unit clearing', 'Business downsizing'],
  },
  {
    img: '/images/sofa-removal.jpg',
    title: 'Furniture & Appliance Removal',
    desc: "No stairs too steep, no appliance too heavy. We carry it all out so you don't have to.",
    items: ['Sofas, sectionals, recliners', 'Beds & bed frames', 'Refrigerators & freezers', 'Washing machines & dryers', 'Hot tubs & exercise equipment'],
  },
  {
    img: '/images/full-trailer.jpg',
    title: 'Yard Waste Removal',
    desc: 'After the storm or after the season — we clear branches, stumps, leaves, and all outdoor debris.',
    items: ['Storm debris & fallen branches', 'Leaf & brush removal', 'Stump & root hauling', 'Old fencing & lumber', 'Soil & mulch disposal'],
  },
  {
    img: '/images/construction-debris.jpg',
    title: 'Construction Debris',
    desc: 'Remodeling? We handle the mess. All construction waste removed quickly and responsibly.',
    items: ['Drywall & lumber', 'Tile & flooring', 'Concrete & masonry', 'Roofing materials', 'Demolition debris'],
  },
  {
    img: '/images/before-after.jpg',
    title: 'Estate Cleanouts',
    desc: 'A compassionate, thorough approach to estate and hoarding cleanouts. We treat every job with discretion and respect.',
    items: ['Full estate clearing', 'Hoarding cleanouts', 'Senior moving assistance', 'Donation coordination', 'Property preparation for sale'],
  },
];
---

<Layout title="Services" description="J&N Junk Removal offers residential, commercial, furniture, yard waste, construction debris, and estate cleanout services across Long Island, NY.">

  <!-- PAGE HEADER -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content">
      <p class="section-label">What We Offer</p>
      <h1 class="section-title light">OUR SERVICES</h1>
      <p class="page-hero-sub">From single-item pickups to full property cleanouts — J&N handles it all across Long Island.</p>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section class="services-section">
    <div class="container">
      {services.map((s, i) => (
        <div class={`service-row ${i % 2 !== 0 ? 'reverse' : ''}`}>
          <div class="service-visual">
            <img src={s.img} alt={s.title} class="service-photo" />
          </div>
          <div class="service-detail">
            <h2 class="service-name">{s.title}</h2>
            <div class="service-divider"></div>
            <p class="service-description">{s.desc}</p>
            <ul class="service-items">
              {s.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <a href="/contact#schedule" class="btn btn-primary">Book This Service</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2 class="cta-title">NEED SOMETHING REMOVED?</h2>
        <p class="cta-sub">Call us or schedule online — we're ready when you are.</p>
      </div>
      <div class="cta-actions">
        <a href="tel:5166725222" class="btn btn-primary">📞 (516) 672-5222</a>
        <a href="/contact#schedule" class="btn btn-outline">Book Online</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* PAGE HERO */
  .page-hero {
    background: var(--black);
    padding: 80px 0 72px;
    position: relative;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 100% at 100% 50%, rgba(211,47,47,0.1) 0%, transparent 70%);
  }

  .page-hero-content { position: relative; z-index: 1; }

  .page-hero-sub {
    color: #888;
    font-size: 1rem;
    margin-top: 16px;
    max-width: 500px;
  }

  /* SERVICES LIST */
  .services-section { padding: 80px 0; }

  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding: 56px 0;
    border-bottom: 1px solid var(--gray-mid);
  }

  .service-row:last-child { border-bottom: none; }

  .service-row.reverse { direction: rtl; }
  .service-row.reverse > * { direction: ltr; }

  .service-visual {
    overflow: hidden;
    position: relative;
  }

  .service-photo {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .service-visual:hover .service-photo { transform: scale(1.04); }

  .service-name {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    letter-spacing: 1px;
    color: var(--black);
    margin-bottom: 14px;
    line-height: 1.1;
  }

  .service-divider {
    width: 48px;
    height: 3px;
    background: var(--red);
    margin-bottom: 18px;
  }

  .service-description {
    font-size: 1rem;
    color: var(--gray-text);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .service-items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
    margin-bottom: 28px;
  }

  .service-items li {
    font-size: 0.9rem;
    color: var(--black);
    padding-left: 14px;
    position: relative;
  }

  .service-items li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--red);
    font-weight: 700;
  }

  /* CTA */
  .cta-banner { background: var(--red); padding: 72px 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .cta-title { font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--white); line-height: 1.1; margin-bottom: 8px; }
  .cta-sub { color: rgba(255,255,255,0.8); font-size: 1rem; }
  .cta-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .service-row, .service-row.reverse { grid-template-columns: 1fr; direction: ltr; gap: 24px; }
    .service-photo { aspect-ratio: 16/9; }
    .cta-inner { flex-direction: column; text-align: center; }
  }

  @media (max-width: 640px) {
    .service-items { grid-template-columns: 1fr; }
  }
</style>
