---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <div class="hero-text">
        <p class="section-label">Long Island's #1 Junk Removal</p>
        <h1 class="hero-title">WE HAUL<br /><span>IT ALL.</span></h1>
        <p class="hero-subtitle">Fast, affordable junk removal across Nassau & Suffolk County. Same-day service available — call or schedule online.</p>
        <div class="hero-actions">
          <a href="tel:5166725222" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.12-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call (516) 672-5222
          </a>
          <a href="/contact#schedule" class="btn btn-outline">Book a Pickup</a>
        </div>
        <div class="hero-badges">
          <div class="badge">✓ Same-Day Available</div>
          <div class="badge">✓ Free Estimates</div>
          <div class="badge">✓ Licensed & Insured</div>
        </div>
      </div>
      <div class="hero-logo-wrap">
        <div class="hero-logo-box">
          <img src="/images/logo.png" alt="J&N Junk Removal Logo" class="hero-logo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
          <div class="hero-logo-fallback">
            <span class="logo-fallback-text">J<span>&</span>N</span>
            <span class="logo-fallback-sub">JUNK REMOVAL</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════ STATS STRIP ═══════════════ -->
  <section class="stats-strip">
    <div class="container stats-grid">
      <div class="stat">
        <span class="stat-num">500<span class="stat-plus">+</span></span>
        <span class="stat-label">Jobs Completed</span>
      </div>
      <div class="stat">
        <span class="stat-num">5<span class="stat-plus">★</span></span>
        <span class="stat-label">Average Rating</span>
      </div>
      <div class="stat">
        <span class="stat-num">Same<span class="stat-plus">-Day</span></span>
        <span class="stat-label">Service Available</span>
      </div>
      <div class="stat">
        <span class="stat-num">100<span class="stat-plus">%</span></span>
        <span class="stat-label">Satisfaction Guarantee</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════ ABOUT ═══════════════ -->
  <section class="about">
    <div class="container about-inner">
      <div class="about-visual">
        <div class="about-img-block">
          <div class="about-img-placeholder">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <p>Add your team/truck photo here</p>
          </div>
          <div class="about-accent-box">
            <span class="accent-year">Local</span>
            <span class="accent-text">Long Island Team</span>
          </div>
        </div>
      </div>
      <div class="about-text">
        <p class="section-label">About Us</p>
        <h2 class="section-title">YOUR LOCAL<br />JUNK REMOVAL<br />EXPERTS</h2>
        <div class="about-divider"></div>
        <p class="about-desc">J&N Junk Removal is a Long Island–based hauling company serving Nassau and Suffolk County. We're your neighbors — and we take pride in showing up on time, doing the job right, and leaving your space spotless.</p>
        <p class="about-desc" style="margin-top:14px;">Whether it's a single couch or a whole house cleanout, we handle it with professionalism and care. No job too big or small.</p>
        <div class="about-features">
          <div class="feature-item">
            <div class="feature-icon">🚛</div>
            <div>
              <strong>Full-Service Hauling</strong>
              <p>We load, haul, and dispose — you just point.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">♻️</div>
            <div>
              <strong>Eco-Responsible</strong>
              <p>We donate, recycle, and dispose responsibly.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">💰</div>
            <div>
              <strong>Upfront Pricing</strong>
              <p>Free estimates, no hidden fees, ever.</p>
            </div>
          </div>
        </div>
        <a href="/contact" class="btn btn-primary" style="margin-top:28px;">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SERVICES PREVIEW ═══════════════ -->
  <section class="services-preview">
    <div class="container">
      <div class="section-header">
        <p class="section-label">What We Do</p>
        <h2 class="section-title light">OUR SERVICES</h2>
      </div>
      <div class="services-grid">
        {[
          { icon: '🏠', title: 'Residential Cleanouts', desc: 'Full home and apartment cleanouts. We haul everything from furniture to appliances.' },
          { icon: '🏢', title: 'Commercial Cleanouts', desc: 'Office, retail, and warehouse cleanouts. Minimal disruption to your business.' },
          { icon: '🛋️', title: 'Furniture & Appliances', desc: 'Old sofas, fridges, mattresses — we take it all off your hands.' },
          { icon: '🌿', title: 'Yard Waste Removal', desc: 'Branches, leaves, stumps, and debris cleared fast.' },
          { icon: '🏗️', title: 'Construction Debris', desc: 'Demo waste, drywall, wood, tile — cleared from any job site.' },
          { icon: '🏡', title: 'Estate Cleanouts', desc: 'Compassionate, thorough estate and hoarding cleanouts.' },
        ].map(s => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h3 class="service-title">{s.title}</h3>
            <p class="service-desc">{s.desc}</p>
            <a href="/services" class="service-link">Learn more →</a>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:48px;">
        <a href="/services" class="btn btn-primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
  <section class="how-it-works">
    <div class="container">
      <div class="section-header center">
        <p class="section-label">Simple Process</p>
        <h2 class="section-title">HOW IT WORKS</h2>
      </div>
      <div class="steps-grid">
        <div class="step">
          <div class="step-num">01</div>
          <h3>Book Online or Call</h3>
          <p>Schedule online or call <a href="tel:5166725222">(516) 672-5222</a>. We'll confirm your appointment fast.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">02</div>
          <h3>We Show Up</h3>
          <p>Our crew arrives on time with all the equipment needed. You show us what goes.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">03</div>
          <h3>We Haul It Away</h3>
          <p>We load everything, sweep up, and you're left with a clean, clear space.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA BANNER ═══════════════ -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2 class="cta-title">READY TO CLEAR THE CLUTTER?</h2>
        <p class="cta-sub">Same-day and next-day pickups available across Long Island.</p>
      </div>
      <div class="cta-actions">
        <a href="tel:5166725222" class="btn btn-primary">📞 (516) 672-5222</a>
        <a href="/contact#schedule" class="btn btn-outline">Schedule Online</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: calc(100vh - 70px);
    background: var(--black);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse 60% 80% at 80% 50%, rgba(211,47,47,0.12) 0%, transparent 70%),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.015) 40px,
        rgba(255,255,255,0.015) 41px
      );
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding-top: 60px;
    padding-bottom: 80px;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 9vw, 7rem);
    line-height: 0.95;
    color: var(--white);
    letter-spacing: 2px;
    margin-bottom: 20px;
  }
  .hero-title span { color: var(--red); }

  .hero-subtitle {
    font-size: 1.1rem;
    color: #aaa;
    line-height: 1.7;
    max-width: 440px;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .hero-badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .badge {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    color: #ccc;
    font-size: 0.8rem;
    font-family: var(--font-condensed);
    font-weight: 600;
    letter-spacing: 1px;
    padding: 6px 14px;
  }

  .hero-logo-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-logo-box {
    width: 360px;
    height: 360px;
    border: 2px solid rgba(211,47,47,0.3);
    background: rgba(211,47,47,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .hero-logo-box::before {
    content: '';
    position: absolute;
    inset: -8px;
    border: 1px solid rgba(211,47,47,0.15);
  }

  .hero-logo { width: 100%; height: 100%; object-fit: contain; padding: 30px; }

  .hero-logo-fallback {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .logo-fallback-text {
    font-family: var(--font-display);
    font-size: 5rem;
    color: var(--white);
    line-height: 1;
  }
  .logo-fallback-text span { color: var(--red); }

  .logo-fallback-sub {
    font-family: var(--font-condensed);
    font-weight: 900;
    font-size: 1.2rem;
    color: var(--red);
    letter-spacing: 4px;
    margin-top: 8px;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: #555;
    font-size: 0.7rem;
    font-family: var(--font-condensed);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--red), transparent);
    animation: scrollPulse 1.5s infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  /* STATS */
  .stats-strip {
    background: var(--red);
    padding: 32px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px;
    border-right: 1px solid rgba(255,255,255,0.2);
  }
  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2.6rem;
    color: var(--white);
    line-height: 1;
  }

  .stat-plus {
    font-size: 1.6rem;
    color: rgba(255,255,255,0.7);
  }

  .stat-label {
    font-family: var(--font-condensed);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    margin-top: 4px;
  }

  /* ABOUT */
  .about {
    padding: 100px 0;
    background: var(--white);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 72px;
    align-items: center;
  }

  .about-img-block {
    position: relative;
  }

  .about-img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--gray-light);
    border: 2px dashed var(--gray-mid);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--gray-text);
    font-size: 0.9rem;
    text-align: center;
    padding: 20px;
  }

  .about-img-placeholder svg { opacity: 0.3; }

  .about-accent-box {
    position: absolute;
    bottom: -24px;
    right: -24px;
    background: var(--red);
    color: var(--white);
    padding: 20px 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .accent-year {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
  }

  .accent-text {
    font-family: var(--font-condensed);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.9;
    margin-top: 4px;
  }

  .about-divider {
    width: 60px;
    height: 4px;
    background: var(--red);
    margin: 20px 0;
  }

  .about-desc { font-size: 1rem; color: var(--gray-text); line-height: 1.8; }

  .about-features {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .feature-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .feature-icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feature-item strong {
    display: block;
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 2px;
  }

  .feature-item p { font-size: 0.9rem; color: var(--gray-text); }

  /* SERVICES PREVIEW */
  .services-preview {
    background: var(--black);
    padding: 100px 0;
  }

  .section-header {
    margin-bottom: 56px;
  }

  .section-header.center { text-align: center; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--black-3);
  }

  .service-card {
    background: var(--black-2);
    padding: 36px 28px;
    transition: background 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--red);
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .service-card:hover { background: var(--black-3); transform: translateY(-4px); }
  .service-card:hover::before { transform: scaleX(1); }

  .service-icon { font-size: 2.2rem; margin-bottom: 14px; }

  .service-title {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 10px;
  }

  .service-desc {
    font-size: 0.9rem;
    color: #888;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .service-link {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--red);
    transition: gap 0.2s;
  }

  .service-link:hover { color: var(--red-light); }

  /* HOW IT WORKS */
  .how-it-works {
    padding: 100px 0;
    background: var(--gray-light);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 24px;
    align-items: start;
    margin-top: 56px;
  }

  .step {
    background: var(--white);
    padding: 36px 28px;
    border-top: 4px solid var(--red);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--red);
    line-height: 1;
    margin-bottom: 12px;
    opacity: 0.7;
  }

  .step h3 {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 10px;
  }

  .step p { font-size: 0.9rem; color: var(--gray-text); line-height: 1.7; }
  .step p a { color: var(--red); font-weight: 700; }

  .step-arrow {
    font-size: 2rem;
    color: var(--red);
    align-self: center;
    font-weight: 900;
  }

  /* CTA */
  .cta-banner {
    background: var(--red);
    padding: 72px 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .cta-sub {
    color: rgba(255,255,255,0.8);
    font-size: 1rem;
  }

  .cta-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .hero-content { grid-template-columns: 1fr; gap: 40px; }
    .hero-logo-wrap { display: none; }
    .about-inner { grid-template-columns: 1fr; }
    .about-img-block { display: none; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .step-arrow { display: none; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-inner { flex-direction: column; text-align: center; }
  }

  @media (max-width: 600px) {
    .hero { min-height: auto; padding: 48px 0 60px; }
    .services-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
