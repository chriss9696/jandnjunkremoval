---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero">
    <div class="hero-bg-img">
      <img src="/images/hero-bg.jpg" alt="J&N Junk Removal crew loading couch into trailer" />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-text">
        <p class="section-label">Long Island's #1 Junk Removal</p>
        <h1 class="hero-title">WE HAUL<br /><span>IT ALL.</span></h1>
        <p class="hero-subtitle">Fast, affordable junk removal across Nassau &amp; Suffolk County. Same-day service available — call or schedule online.</p>
        <div class="hero-actions">
          <a href="tel:5166725222" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.12-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call (516) 672-5222
          </a>
          <a href="/contact#schedule" class="btn btn-outline">Book a Pickup</a>
        </div>
        <div class="hero-badges">
          <div class="badge">✓ Same-Day Available</div>
          <div class="badge">✓ Free Estimates</div>
          <div class="badge">✓ No Hidden Fees</div>
        </div>
      </div>
      <div class="hero-logo-wrap">
        <img src="/images/logo-transparent.png" alt="J&N Junk Removal" class="hero-logo-img" />
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════ ABOUT ═══════════════ -->
  <section class="about">
    <div class="container about-inner">
      <div class="about-visual">
        <div class="about-img-block">
          <img
            src="/images/about-team.jpg"
            alt="J&N Junk Removal crew ready to work"
            class="about-img"
          />
          <div class="about-accent-box">
            <span class="accent-top">Local</span>
            <span class="accent-bottom">Long Island Team</span>
          </div>
        </div>
      </div>
      <div class="about-text">
        <p class="section-label">About Us</p>
        <h2 class="section-title">YOUR LOCAL<br />JUNK REMOVAL<br />EXPERTS</h2>
        <div class="about-divider"></div>
        <p class="about-desc">J&N Junk Removal is a Long Island–based hauling company serving Nassau and Suffolk County. We're your neighbors — and we take pride in showing up on time, doing the job right, and leaving your space spotless.</p>
        <p class="about-desc" style="margin-top:14px;">Whether it's a single couch or a whole house cleanout, we handle it with professionalism and care. No job too big or small.</p>
        <div class="about-features">
          <div class="feature-item">
            <div class="feature-icon">🚛</div>
            <div>
              <strong>Full-Service Hauling</strong>
              <p>We load, haul, and dispose — you just point.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">♻️</div>
            <div>
              <strong>Eco-Responsible</strong>
              <p>We donate, recycle, and dispose responsibly.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-icon">💰</div>
            <div>
              <strong>Upfront Pricing</strong>
              <p>Free estimates, no hidden fees, ever.</p>
            </div>
          </div>
        </div>
        <a href="/contact" class="btn btn-primary" style="margin-top:28px;">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SERVICES PREVIEW ═══════════════ -->
  <section class="services-preview">
    <div class="container">
      <div class="section-header">
        <p class="section-label">What We Do</p>
        <h2 class="section-title light">OUR SERVICES</h2>
      </div>
      <div class="services-grid">
        {[
          { img: '/images/residential-cleanout.jpg',  title: 'Residential Cleanouts',     desc: 'Full home and apartment cleanouts. We haul everything from furniture to appliances, fast and affordably.' },
          { img: '/images/sofa-removal.jpg',           title: 'Furniture & Appliances',    desc: 'Old sofas, fridges, mattresses — we take it all off your hands. No item too heavy.' },
          { img: '/images/construction-debris.jpg',    title: 'Construction Debris',       desc: 'Demo waste, drywall, wood, tile — cleared from any job site quickly and responsibly.' },
          { img: '/images/full-trailer.jpg',           title: 'Full Junk Hauling',         desc: 'No load too big. We fill the trailer and haul it all away — you just show us what goes.' },
          { img: '/images/before-after.jpg',           title: 'Garage & Estate Cleanouts', desc: 'Thorough garage, basement, and estate cleanouts. We leave your space completely clear.' },
          { img: '/images/commercial-cleanout.jpg',    title: 'Commercial Cleanouts',      desc: 'Office, retail, and warehouse cleanouts scheduled around your business hours.' },
        ].map(s => (
          <div class="service-card">
            <div class="service-card-img">
              <img src={s.img} alt={s.title} />
            </div>
            <div class="service-card-body">
              <h3 class="service-title">{s.title}</h3>
              <p class="service-desc">{s.desc}</p>
              <a href="/services" class="service-link">Learn more →</a>
            </div>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:48px;">
        <a href="/services" class="btn btn-primary">View All Services</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PHOTO SHOWCASE ═══════════════ -->
  <section class="photo-showcase">
    <div class="container">
      <div class="section-header center">
        <p class="section-label">Real Jobs</p>
        <h2 class="section-title">SEE OUR WORK</h2>
      </div>
      <div class="photo-grid">
        <div class="photo-item photo-tall">
          <img src="/images/hero-bg.jpg" alt="J&N crew loading couch into trailer" />
          <div class="photo-caption">Our Crew in Action</div>
        </div>
        <div class="photo-item">
          <img src="/images/sofa-removal.jpg" alt="Worker removing old sofa from home" />
          <div class="photo-caption">Furniture Removal</div>
        </div>
        <div class="photo-item">
          <img src="/images/full-trailer.jpg" alt="Full trailer load hauled away" />
          <div class="photo-caption">Full Load Hauled Away</div>
        </div>
        <div class="photo-item">
          <img src="/images/before-after.jpg" alt="Before and after garage cleanout" />
          <div class="photo-caption">Before &amp; After</div>
        </div>
        <div class="photo-item">
          <img src="/images/construction-debris.jpg" alt="Construction debris cleanup" />
          <div class="photo-caption">Construction Debris</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ HOW IT WORKS ═══════════════ -->
  <section class="how-it-works">
    <div class="container">
      <div class="section-header center">
        <p class="section-label">Simple Process</p>
        <h2 class="section-title">HOW IT WORKS</h2>
      </div>
      <div class="steps-grid">
        <div class="step">
          <div class="step-num">01</div>
          <h3>Book Online or Call</h3>
          <p>Schedule online or call <a href="tel:5166725222">(516) 672-5222</a>. We'll confirm your appointment fast.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">02</div>
          <h3>We Show Up</h3>
          <p>Our crew arrives on time with all the equipment needed. You show us what goes.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step">
          <div class="step-num">03</div>
          <h3>We Haul It Away</h3>
          <p>We load everything, sweep up, and you're left with a clean, clear space.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA BANNER ═══════════════ -->
  <section class="cta-banner">
    <div class="container cta-inner">
      <div>
        <h2 class="cta-title">READY TO CLEAR THE CLUTTER?</h2>
        <p class="cta-sub">Same-day and next-day pickups available across Long Island.</p>
      </div>
      <div class="cta-actions">
        <a href="tel:5166725222" class="btn btn-primary">📞 (516) 672-5222</a>
        <a href="/contact#schedule" class="btn btn-outline">Schedule Online</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: calc(100vh - 70px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      rgba(0,0,0,0.93) 0%,
      rgba(0,0,0,0.82) 45%,
      rgba(0,0,0,0.50) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    padding-top: 60px;
    padding-bottom: 80px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 9vw, 7rem);
    line-height: 0.95;
    color: var(--white);
    letter-spacing: 2px;
    margin-bottom: 20px;
  }
  .hero-title span { color: var(--red); }

  .hero-subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    max-width: 440px;
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .hero-badges { display: flex; gap: 12px; flex-wrap: wrap; }

  .badge {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.85);
    font-size: 0.8rem;
    font-family: var(--font-condensed);
    font-weight: 600;
    letter-spacing: 1px;
    padding: 6px 14px;
  }

  .hero-logo-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-logo-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    filter: drop-shadow(0 8px 32px rgba(0,0,0,0.8)) drop-shadow(0 2px 8px rgba(0,0,0,0.9));
  }

  .hero-scroll {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.3);
    font-family: var(--font-condensed);
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    z-index: 1;
  }

  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
  }

  /* ── ABOUT ── */
  .about {
    padding: 100px 0;
    background: var(--white);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 72px;
    align-items: center;
  }

  .about-img-block {
    position: relative;
    padding-bottom: 28px;
    padding-right: 28px;
  }

  .about-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .about-accent-box {
    position: absolute;
    bottom: 0;
    right: 0;
    background: var(--red);
    color: var(--white);
    padding: 18px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .accent-top {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;
  }

  .accent-bottom {
    font-family: var(--font-condensed);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.9;
    margin-top: 4px;
    white-space: nowrap;
  }

  .about-divider {
    width: 60px;
    height: 4px;
    background: var(--red);
    margin: 20px 0;
  }

  .about-desc { font-size: 1rem; color: var(--gray-text); line-height: 1.8; }

  .about-features {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .feature-item { display: flex; gap: 16px; align-items: flex-start; }

  .feature-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }

  .feature-item strong {
    display: block;
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 2px;
  }

  .feature-item p { font-size: 0.9rem; color: var(--gray-text); }

  /* ── SERVICES PREVIEW ── */
  .services-preview {
    background: var(--black);
    padding: 100px 0;
  }

  .section-header { margin-bottom: 48px; }
  .section-header.center { text-align: center; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    background: var(--black-3);
  }

  .service-card {
    background: var(--black-2);
    overflow: hidden;
    transition: transform 0.25s;
    position: relative;
  }

  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--red);
    transform: scaleX(0);
    transition: transform 0.3s;
  }

  .service-card:hover { transform: translateY(-5px); }
  .service-card:hover::after { transform: scaleX(1); }

  .service-card-img { width: 100%; height: 190px; overflow: hidden; }

  .service-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .service-card:hover .service-card-img img { transform: scale(1.07); }

  .service-card-body { padding: 24px 22px 28px; }

  .service-title {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 10px;
  }

  .service-desc { font-size: 0.9rem; color: #888; line-height: 1.7; margin-bottom: 16px; }

  .service-link {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--red);
    transition: color 0.2s;
  }

  .service-link:hover { color: var(--red-light); }

  /* ── PHOTO SHOWCASE ── */
  .photo-showcase {
    padding: 100px 0;
    background: var(--gray-light);
  }

  .photo-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 4px;
    margin-top: 48px;
    height: 560px;
  }

  .photo-tall { grid-row: 1 / 3; }

  .photo-item { position: relative; overflow: hidden; }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .photo-item:hover img { transform: scale(1.05); }

  .photo-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.78));
    color: var(--white);
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 28px 16px 14px;
  }

  /* ── HOW IT WORKS ── */
  .how-it-works {
    padding: 100px 0;
    background: var(--white);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 24px;
    align-items: start;
    margin-top: 56px;
  }

  .step {
    background: var(--gray-light);
    padding: 36px 28px;
    border-top: 4px solid var(--red);
  }

  .step-num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--red);
    line-height: 1;
    margin-bottom: 12px;
    opacity: 0.65;
  }

  .step h3 {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 10px;
  }

  .step p { font-size: 0.9rem; color: var(--gray-text); line-height: 1.7; }
  .step p a { color: var(--red); font-weight: 700; }
  .step-arrow { font-size: 2rem; color: var(--red); align-self: center; }

  /* ── CTA BANNER ── */
  .cta-banner { background: var(--red); padding: 72px 0; }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .cta-sub { color: rgba(255,255,255,0.8); font-size: 1rem; }
  .cta-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .hero-content { grid-template-columns: 1fr; gap: 40px; }
    .hero-logo-wrap { display: none; }
    .about-inner { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .step-arrow { display: none; }
    .cta-inner { flex-direction: column; text-align: center; }
    .photo-grid { height: auto; grid-template-columns: 1fr; grid-template-rows: auto; }
    .photo-tall { grid-row: auto; }
    .photo-item img { min-height: 260px; }
  }

  @media (max-width: 600px) {
    .hero { min-height: auto; padding: 48px 0 72px; }
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
