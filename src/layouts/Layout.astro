---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'J&N Junk Removal – Professional junk removal services in Long Island, NY. Fast, affordable, and reliable. Call (516) 672-5222 today!' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | J&N Junk Removal – Long Island, NY</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <img src="/images/logo.png" alt="J&N Junk Removal" class="nav-logo" />
      </a>
      <ul class="nav-links">
        <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/services" class={currentPath === '/services' ? 'active' : ''}>Services</a></li>
        <li><a href="/contact" class={currentPath === '/contact' ? 'active' : ''}>Contact</a></li>
        <li><a href="tel:5166725222" class="nav-cta">📞 (516) 672-5222</a></li>
      </ul>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <a href="/contact">Contact</a>
    <a href="tel:5166725222" style="color:var(--red);">📞 (516) 672-5222</a>
  </div>

  <main style="padding-top: 70px;">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-brand-name">J<span>&</span>N JUNK REMOVAL</div>
          <p class="footer-desc">Long Island's trusted junk removal team. Fast, affordable, and eco-conscious hauling for homes and businesses across Nassau & Suffolk County.</p>
          <div class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 8.32 8.32l1.12-.96a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:5166725222">(516) 672-5222</a>
          </div>
          <div class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:jnjunkremovalservices@gmail.com">jnjunkremovalservices@gmail.com</a>
          </div>
          <div class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Long Island, NY (516 Area)</span>
          </div>
        </div>

        <div>
          <div class="footer-heading">Quick Links</div>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/services">Our Services</a></li>
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="/contact#schedule">Schedule Pickup</a></li>
          </ul>
        </div>

        <div>
          <div class="footer-heading">Services</div>
          <ul class="footer-links">
            <li><a href="/services">Residential Junk Removal</a></li>
            <li><a href="/services">Commercial Cleanouts</a></li>
            <li><a href="/services">Furniture & Appliances</a></li>
            <li><a href="/services">Yard Waste Removal</a></li>
            <li><a href="/services">Construction Debris</a></li>
            <li><a href="/services">Estate Cleanouts</a></li>
          </ul>
        </div>
      </div>

      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} J&N Junk Removal. All rights reserved.</span>
        <span>Proudly serving Long Island, NY</span>
      </div>
    </div>
  </footer>

  <script>
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    hamburger?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('open');
    });
  </script>
</body>
</html>
